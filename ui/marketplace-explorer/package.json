{
  "name": "@budna/mcp-marketplace-explorer",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "vite build && node scripts/check-asset.mjs",
    "check": "npm run format:check && npm run typecheck && npm run test:run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "axe-core": "4.12.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "terser": "5.49.0",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "4.1.10"
  }
}

# Reference only: budna-mcp does not load .env files automatically.
BUDNA_API_URL=https://api.budna.se/api/v1
BUDNA_PUBLIC_LISTING_ORIGIN=https://budna.se
BUDNA_IMAGE_ORIGIN=https://images.budna.se
BUDNA_MCP_TRANSPORT=stdio
BUDNA_MCP_REQUEST_TIMEOUT_SECS=30
BUDNA_MCP_LOG=warn
BUDNA_MCP_HTTP_PORT=3001
BUDNA_MCP_HTTP_ALLOWED_HOSTS=localhost,127.0.0.1
BUDNA_MCP_HTTP_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
